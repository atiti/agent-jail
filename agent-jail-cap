#!/bin/sh

case "$0" in
  */*) SCRIPT_PARENT="${0%/*}" ;;
  *) SCRIPT_PARENT="." ;;
esac
SCRIPT_DIR="$(CDPATH= cd -- "$SCRIPT_PARENT" && pwd)"
REPO_ROOT="${AGENT_JAIL_SOURCE_ROOT:-$SCRIPT_DIR}"
PYTHON_BIN="${AGENT_JAIL_PYTHON:-python3}"

if [ -n "$PYTHONPATH" ]; then
  export PYTHONPATH="$REPO_ROOT:$PYTHONPATH"
else
  export PYTHONPATH="$REPO_ROOT"
fi

exec "$PYTHON_BIN" -m agent_jail.cap_cli "$@"
