#!/bin/sh

SCRIPT_PATH="$0"
REPO_ROOT="$(python3 - "$SCRIPT_PATH" <<'PY'
import os
import sys

print(os.path.dirname(os.path.realpath(sys.argv[1])))
PY
)"

if [ -n "$PYTHONPATH" ]; then
  export PYTHONPATH="$REPO_ROOT:$PYTHONPATH"
else
  export PYTHONPATH="$REPO_ROOT"
fi

exec python3 -m agent_jail.cap_cli "$@"
